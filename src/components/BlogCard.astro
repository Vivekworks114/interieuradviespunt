---
interface Props {
  title: string;
  href: string;
  image: string;
  date?: string;
  excerpt?: string;
}

const { title, href, image, date, excerpt } = Astro.props;
const formattedDate = date
  ? new Date(date).toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---
<article class="blog-card card">
  <a href={href} class="blog-card__link">
    <div class="blog-card__image-wrap">
      <img src={image} alt={title} class="card__image" width="800" height="528" loading="lazy" />
    </div>
    <div class="card__body blog-card__body">
      {formattedDate && <time class="blog-card__date" datetime={date}>{formattedDate}</time>}
      <h3 class="card__title">{title}</h3>
      {excerpt && <p class="blog-card__excerpt">{excerpt}</p>}
      <span class="blog-card__read-more">
        Lees verder »
      </span>
    </div>
  </a>
</article>

<style>
  .blog-card__link {
    display: block;
    color: inherit;
  }

  .blog-card__image-wrap {
    overflow: hidden;
  }

  .blog-card__image-wrap .card__image {
    aspect-ratio: 3 / 2;
    transition: transform 0.5s ease;
  }

  .blog-card:hover .card__image {
    transform: scale(1.04);
  }

  .blog-card__body {
    padding: 1.25rem;
  }

  .blog-card__date {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .blog-card__excerpt {
    font-size: 0.9375rem;
    color: var(--color-muted);
    margin: 0.5rem 0 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__read-more {
    font-size: 0.875rem;
    color: var(--color-accent);
    transition: color var(--transition);
  }

  .blog-card:hover .blog-card__read-more {
    color: var(--color-accent-hover);
  }
</style>
