---
import { mainNavigation, socialLinks } from '../data/navigation';
import Navigation from './Navigation.astro';

const currentPath = Astro.url.pathname;
---
<header class="header">
  <div class="header__inner container">
    <a href="/" class="header__logo" aria-label="Interieuradviespunt.nl - Home">
      <img src="/images/2022/08/Frame-191.svg" alt="Interieuradviespunt.nl" width="202" height="32" />
    </a>

    <div class="header__actions">
      <button class="search-toggle" type="button" aria-label="Zoeken">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
      <button class="nav-toggle" type="button" aria-label="Menu openen" aria-expanded="false">
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
      </button>
    </div>
  </div>

  <Navigation items={mainNavigation} currentPath={currentPath} />
</header>

<div class="search-overlay" role="dialog" aria-label="Zoeken">
  <div class="search-overlay__content">
    <button class="search-close" type="button" aria-label="Sluiten">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
    <form class="search-form" action="/" method="get">
      <label for="site-search" class="sr-only">Zoeken</label>
      <input id="site-search" type="search" name="s" placeholder="Zoeken..." autocomplete="off" />
    </form>
  </div>
</div>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--color-bg);
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition), box-shadow var(--transition);
    overflow: visible;
  }

  .header--scrolled {
    border-bottom-color: var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding-block: 0.875rem;
  }

  .header__logo img {
    width: min(202px, 45vw);
    height: auto;
    transition: opacity var(--transition);
  }

  .header__logo:hover img {
    opacity: 0.85;
  }

  .header__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
  }

  .search-toggle,
  .nav-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    color: var(--color-primary);
    transition: color var(--transition);
  }

  .search-toggle:hover {
    color: var(--color-accent);
  }

  .nav-toggle {
    flex-direction: column;
    gap: 5px;
    width: 33px;
    height: 33px;
  }

  .nav-toggle__bar {
    display: block;
    width: 22px;
    height: 2px;
    background: currentColor;
    transition: transform var(--transition), opacity var(--transition);
  }

  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(38, 38, 38, 0.96);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition), visibility var(--transition);
  }

  .search-overlay--active {
    opacity: 1;
    visibility: visible;
  }

  .search-overlay__content {
    width: min(90%, 600px);
    position: relative;
  }

  .search-close {
    position: absolute;
    top: -3rem;
    right: 0;
    background: none;
    border: none;
    color: var(--color-primary);
    cursor: pointer;
    padding: 0.5rem;
  }

  .search-form input {
    width: 100%;
    padding: 1rem 0;
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-family: var(--font-body);
    background: transparent;
    border: none;
    border-bottom: 2px solid var(--color-accent);
    color: var(--color-primary);
    outline: none;
  }

  .search-form input::placeholder {
    color: var(--color-muted);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  @media (min-width: 1024px) {
    .header__inner {
      grid-template-columns: auto 1fr auto;
    }

    .nav-toggle {
      display: none;
    }
  }

  @media (max-width: 1023px) {
    .nav-toggle {
      display: flex;
    }
  }
</style>

<script>
  const header = document.querySelector('.header');
  const updateHeader = () => {
    header?.classList.toggle('header--scrolled', window.scrollY > 8);
  };
  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });

  const overlay = document.querySelector('.search-overlay');
  const openBtn = document.querySelector('.search-toggle');
  const closeBtn = document.querySelector('.search-close');
  const input = document.querySelector('#site-search');

  const openSearch = () => {
    overlay?.classList.add('search-overlay--active');
    document.body.style.overflow = 'hidden';
    window.setTimeout(() => input?.focus(), 40);
  };

  const closeSearch = () => {
    overlay?.classList.remove('search-overlay--active');
    document.body.style.overflow = '';
    input?.blur();
  };

  openBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    if (overlay?.classList.contains('search-overlay--active')) closeSearch();
    else openSearch();
  });

  closeBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    closeSearch();
  });

  overlay?.addEventListener('click', (e) => {
    const target = e.target;
    if (target instanceof Element && target.closest('input, label, .search-form')) return;
    closeSearch();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
  });
</script>
