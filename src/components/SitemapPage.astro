---
import type { SitemapEntryLike } from '../data/sitemapTypes';

interface Props {
  entries: SitemapEntryLike[];
}

const { entries } = Astro.props;

const pages = entries
  .filter((e) => e.kind === 'page' || e.kind === 'home')
  .sort((a, b) => a.label.localeCompare(b.label, 'nl'));

const products = entries
  .filter((e) => e.kind === 'product')
  .sort((a, b) => a.label.localeCompare(b.label, 'nl'));

const blogs = entries
  .filter((e) => e.kind === 'blog')
  .sort((a, b) => a.label.localeCompare(b.label, 'nl'));

const categories = entries
  .filter((e) => e.kind === 'category')
  .sort((a, b) => a.label.localeCompare(b.label, 'nl'));

const directory = entries
  .filter((e) => e.kind === 'entry')
  .sort((a, b) => a.label.localeCompare(b.label, 'nl'));

const directoryLetters = [
  ...new Set(
    directory.map((item) => {
      const ch = item.label.trim().charAt(0).toUpperCase();
      return /[A-Z]/.test(ch) ? ch : '#';
    })
  ),
].sort((a, b) => {
  if (a === '#') return -1;
  if (b === '#') return 1;
  return a.localeCompare(b, 'nl');
});

const sections = [
  { id: 'paginas', title: "Pagina's", count: pages.length, items: pages },
  { id: 'producten', title: 'Productgidsen', count: products.length, items: products },
  { id: 'blog', title: 'Blogartikelen', count: blogs.length, items: blogs },
  { id: 'categorieen', title: 'Categorieën', count: categories.length, items: categories },
];
---
<section class="sm-hero">
  <div class="sm-hero__glow" aria-hidden="true"></div>
  <div class="container sm-hero__content">
    <p class="sm-hero__eyebrow reveal">Overzicht</p>
    <h1 class="sm-hero__title reveal">Sitemap</h1>
    <p class="sm-hero__lead reveal">
      Alle pagina's, productgidsen, artikelen en directory-items op één plek. Kies een sectie of spring naar een letter.
    </p>
    <div class="sm-hero__stats reveal">
      <div><strong>{pages.length}</strong><span>Pagina's</span></div>
      <div><strong>{products.length}</strong><span>Producten</span></div>
      <div><strong>{blogs.length}</strong><span>Artikelen</span></div>
      <div><strong>{directory.length}</strong><span>Directory</span></div>
    </div>
  </div>
</section>

<nav class="sm-jump" aria-label="Spring naar sectie">
  <div class="container sm-jump__inner">
    {sections.map((section) => (
      <a class="sm-jump__link" href={`#${section.id}`}>{section.title}</a>
    ))}
    <a class="sm-jump__link" href="#directory">Directory</a>
  </div>
</nav>

{sections.map((section) => (
  <section class="sm-section" id={section.id}>
    <div class="container">
      <div class="sm-section__head reveal">
        <h2>{section.title}</h2>
        <span>{section.count} links</span>
      </div>
      <div class="sm-grid">
        {section.items.map((item, index) => (
          <a
            href={item.path}
            class="sm-card reveal"
            style={`transition-delay: ${Math.min(index, 12) * 0.03}s`}
          >
            <span class="sm-card__label">{item.label}</span>
            <span class="sm-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>
))}

<section class="sm-section sm-section--directory" id="directory">
  <div class="container">
    <div class="sm-section__head reveal">
      <h2>Directory</h2>
      <span>{directory.length} links</span>
    </div>

    <nav class="sm-letters" aria-label="Directory letters">
      {directoryLetters.map((letter) => (
        <a class="sm-letters__link" href={`#dir-${letter === '#' ? 'num' : letter}`}>{letter}</a>
      ))}
    </nav>

    {directoryLetters.map((letter) => {
      const group = directory.filter((item) => {
        const ch = item.label.trim().charAt(0).toUpperCase();
        const key = /[A-Z]/.test(ch) ? ch : '#';
        return key === letter;
      });
      const id = letter === '#' ? 'dir-num' : `dir-${letter}`;
      return (
        <div class="sm-dir-group" id={id}>
          <div class="sm-dir-group__head reveal">
            <span class="sm-dir-group__letter">{letter}</span>
            <span class="sm-dir-group__count">{group.length}</span>
          </div>
          <div class="sm-dir-grid">
            {group.map((item) => (
              <a href={item.path} class="sm-dir-link">{item.label}</a>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .sm-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(4rem, 9vw, 6.5rem) 0 clamp(2.5rem, 5vw, 3.5rem);
    background:
      radial-gradient(ellipse 80% 60% at 10% 0%, rgba(177, 141, 77, 0.18), transparent 55%),
      linear-gradient(180deg, #2a2a2a 0%, var(--color-bg) 100%);
  }

  .sm-hero__glow {
    position: absolute;
    inset: auto -10% -40% 40%;
    height: 70%;
    background: radial-gradient(circle, rgba(177, 141, 77, 0.12), transparent 65%);
    z-index: -1;
  }

  .sm-hero__content {
    max-width: 42rem;
  }

  .sm-hero__eyebrow {
    margin: 0 0 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .sm-hero__title {
    margin: 0 0 0.85rem;
    font-size: clamp(2.75rem, 8vw, 5rem);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .sm-hero__lead {
    margin: 0 0 1.75rem;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.65;
  }

  .sm-hero__stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  @media (min-width: 700px) {
    .sm-hero__stats {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .sm-hero__stats div {
    padding: 0.9rem 1rem;
    border: 1px solid var(--color-border);
    background: rgba(46, 46, 46, 0.55);
  }

  .sm-hero__stats strong {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--color-accent);
    line-height: 1.1;
  }

  .sm-hero__stats span {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .sm-jump {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(38, 38, 38, 0.92);
    backdrop-filter: blur(10px);
    border-block: 1px solid var(--color-border);
  }

  .sm-jump__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-block: 0.75rem;
  }

  .sm-jump__link {
    padding: 0.45rem 0.8rem;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid transparent;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .sm-jump__link:hover,
  .sm-jump__link:focus-visible {
    color: var(--color-primary);
    border-color: var(--color-accent);
    background: rgba(177, 141, 77, 0.12);
  }

  .sm-section {
    padding-block: clamp(2.25rem, 5vw, 3.75rem);
  }

  .sm-section + .sm-section {
    border-top: 1px solid var(--color-border);
  }

  .sm-section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .sm-section__head h2 {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .sm-section__head span {
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .sm-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.65rem;
  }

  @media (min-width: 640px) {
    .sm-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 960px) {
    .sm-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .sm-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.95rem 1rem;
    background: var(--color-bg-elevated);
    border: 1px solid transparent;
    color: inherit;
    transition: border-color var(--transition), transform var(--transition), background var(--transition);
  }

  .sm-card:hover,
  .sm-card:focus-visible {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    background: #333;
  }

  .sm-card__label {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .sm-card__arrow {
    color: var(--color-accent);
    opacity: 0.75;
  }

  .sm-letters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
  }

  .sm-letters__link {
    min-width: 2.1rem;
    height: 2.1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-muted);
    border: 1px solid transparent;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .sm-letters__link:hover,
  .sm-letters__link:focus-visible {
    color: var(--color-primary);
    border-color: var(--color-accent);
    background: rgba(177, 141, 77, 0.12);
  }

  .sm-dir-group + .sm-dir-group {
    margin-top: 1.75rem;
  }

  .sm-dir-group__head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .sm-dir-group__letter {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
  }

  .sm-dir-group__count {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .sm-dir-grid {
    columns: 1;
    gap: 1.5rem;
  }

  @media (min-width: 700px) {
    .sm-dir-grid {
      columns: 2;
    }
  }

  @media (min-width: 1000px) {
    .sm-dir-grid {
      columns: 3;
    }
  }

  .sm-dir-link {
    display: block;
    padding: 0.35rem 0;
    color: var(--color-muted);
    break-inside: avoid;
    transition: color var(--transition);
  }

  .sm-dir-link:hover,
  .sm-dir-link:focus-visible {
    color: var(--color-accent);
  }
</style>
