---
import type { NavItem } from '../data/navigation';

interface Props {
  items: NavItem[];
  currentPath: string;
}

const { items, currentPath } = Astro.props;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href.replace(/\/$/, ''));
}
---
<nav class="nav" aria-label="Hoofdnavigatie">
  <ul class="nav__list">
    {items.map((item) => (
      <li class:list={['nav-item', { 'nav-item--has-children': item.children?.length }]}>
        <a
          href={item.href}
          class:list={['nav-link', { 'nav-link--active': isActive(item.href) }]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
        {item.children && (
          <ul class="nav__submenu">
            {item.children.map((child) => (
              <li>
                <a href={child.href} class:list={['nav-sublink', { 'nav-sublink--active': isActive(child.href) }]}>
                  {child.label}
                </a>
              </li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>
</nav>

<style>
  .nav__list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: block;
    padding: 0.875rem 1rem;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-primary);
    transition: color var(--transition);
  }

  .nav-link:hover,
  .nav-link--active {
    color: var(--color-accent);
  }

  .nav__submenu {
    display: none;
    padding-left: 1rem;
    background: var(--color-bg-elevated);
  }

  .nav-item--expanded .nav__submenu {
    display: block;
  }

  .nav-sublink {
    display: block;
    padding: 0.625rem 1rem;
    font-size: 0.9375rem;
    color: var(--color-muted);
    transition: color var(--transition);
  }

  .nav-sublink:hover,
  .nav-sublink--active {
    color: var(--color-accent);
  }

  @media (min-width: 1024px) {
    .nav__list {
      flex-direction: row;
      align-items: center;
      gap: 0.25rem;
    }

    .nav-link {
      padding: 0.5rem 1rem;
      font-size: 0.9375rem;
    }

    .nav__submenu {
      position: absolute;
      top: 100%;
      left: 0;
      min-width: 220px;
      padding: 0.5rem 0;
      border: 1px solid var(--color-border);
      box-shadow: var(--shadow-md);
      z-index: 100;
    }

    .nav-item--has-children:hover .nav__submenu,
    .nav-item--has-children:focus-within .nav__submenu {
      display: block;
    }

    .nav--open {
      position: static;
      background: transparent;
      padding: 0;
    }
  }

  @media (max-width: 1023px) {
    .nav {
      position: fixed;
      inset: 0;
      top: 60px;
      z-index: 999;
      background: var(--color-bg);
      padding: 1rem;
      transform: translateX(100%);
      transition: transform var(--transition);
      overflow-y: auto;
    }

    .nav--open {
      transform: translateX(0);
    }
  }
</style>
