---
import { getCollection } from 'astro:content';
import { footerCategories } from '../data/categories';
import { socialLinks } from '../data/navigation';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---
<footer class="footer">
  <div class="container footer__share reveal">
    <h2 class="footer__share-title">Zie ook</h2>
    <p class="footer__share-text">YouTube likes nu beschikbaar</p>
  </div>

  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo">
        <img src="/images/2022/08/Frame-191.svg" alt="Interieuradviespunt.nl" width="202" height="32" loading="lazy" />
      </a>
      <p class="footer__tagline">
        Interieuradviespunt.nl is ideaal voor iedereen die graag het interieur een keer aanpakt of zelf verschillende interieurstijlen wil uitproberen.
      </p>
      <nav class="footer__legal" aria-label="Footer links">
        <a href="/sitemap/">Sitemap</a>
        <a href="/blog/">Blog</a>
        <a href="/architectenbureaus/">Architectenbureaus</a>
      </nav>
      <div class="footer__social" aria-label="Social media">
        {socialLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
            {link.icon === 'facebook' && <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.413c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.971H15.83c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>}
            {link.icon === 'instagram' && <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>}
            {link.icon === 'twitter' && <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>}
            {link.icon === 'youtube' && <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.6 15.6V8.4L15.8 12l-6.2 3.6z"/></svg>}
          </a>
        ))}
      </div>
      <p class="footer__copyright">&copy; 2026 All rights reserved</p>
    </div>

    <div class="footer__column">
      <h3 class="footer__heading">Laatste nieuws</h3>
      <ul class="footer__posts">
        {recentPosts.map((post) => (
          <li>
            <a href={`/${post.id}/`}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    </div>

    {footerCategories.map((cat) => (
      <div class="footer__column">
        <h3 class="footer__heading">{cat.title}</h3>
        <ul class="footer__links">
          {cat.links.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding: clamp(2.25rem, 5vw, 4.5rem) 0 clamp(2rem, 4vw, 3rem);
  }

  .footer__share {
    text-align: center;
    padding-bottom: clamp(2rem, 4vw, 3rem);
    margin-bottom: clamp(2rem, 4vw, 3rem);
    border-bottom: 1px solid var(--color-border);
  }

  .footer__share-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 0.5rem;
  }

  .footer__share-text {
    color: var(--color-muted);
    margin: 0;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
  }

  .footer__logo img {
    width: min(202px, 60vw);
    height: auto;
    margin-bottom: 1rem;
  }

  .footer__tagline {
    font-size: 0.875rem;
    line-height: 1.8;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
    max-width: 320px;
  }

  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .footer__legal a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary);
    transition: color var(--transition);
  }

  .footer__legal a:hover {
    color: var(--color-accent);
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .footer__social a {
    color: var(--color-accent);
    transition: color var(--transition), transform var(--transition);
  }

  .footer__social a:hover {
    color: var(--color-accent-hover);
    transform: translateY(-2px);
  }

  .footer__copyright {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0;
  }

  .footer__heading {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .footer__posts a,
  .footer__links a {
    font-size: 0.875rem;
    line-height: 2;
    color: var(--color-muted);
    transition: color var(--transition);
  }

  .footer__posts a:hover,
  .footer__links a:hover {
    color: var(--color-accent);
  }

  @media (min-width: 768px) {
    .footer__inner {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .footer__inner {
      grid-template-columns: 32% 16% 15% 14% 21%;
    }

    .footer__brand {
      grid-column: auto;
    }
  }
</style>
