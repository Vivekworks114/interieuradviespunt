---
import { featuredReviews } from '../data/categories';
---
<section class="testimonials section section--sm">
  <div class="container">
    <div class="card-grid card-grid--3">
      {featuredReviews.map((review, index) => (
        <article class="testimonial-card reveal" style={`transition-delay: ${index * 0.08}s`}>
          <div class="testimonial-card__image">
            <img src={review.image} alt={review.alt} width="550" height="550" loading="lazy" />
          </div>
          <div class="testimonial-card__body">
            <span class="testimonial-card__category">{review.category}:</span>
            <h3 class="testimonial-card__title">{review.title}</h3>
            <p>{review.excerpt}</p>
            <a href={review.href} class="btn btn--ghost">
              Lees Meer
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonial-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
  }

  .testimonial-card__image {
    aspect-ratio: 1;
    overflow: hidden;
  }

  .testimonial-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .testimonial-card:hover .testimonial-card__image img {
    transform: scale(1.04);
  }

  .testimonial-card__body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .testimonial-card__category {
    font-size: 0.875rem;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .testimonial-card__title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .testimonial-card__body p {
    color: var(--color-muted);
    font-size: 0.9375rem;
    flex: 1;
  }

  .testimonial-card__body .btn {
    margin-top: 1rem;
    align-self: flex-start;
    padding: 0;
    border: none;
    text-transform: none;
    font-size: 0.9375rem;
  }
</style>
