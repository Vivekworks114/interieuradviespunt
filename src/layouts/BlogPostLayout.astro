---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const featuredImage = entry.data.featuredImage ?? '/images/2023/05/wanddecoratie.jpg';
const imageAlt = entry.data.imageAlt ?? entry.data.title;
const formattedDate = entry.data.pubDate.toLocaleDateString('nl-NL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout title={entry.data.title} description={entry.data.description} image={featuredImage}>
  <slot name="header" slot="header" />
  <article class="blog-post">
    <header class="blog-post__header">
      <div class="container">
        <time class="blog-post__date" datetime={entry.data.pubDate.toISOString()}>{formattedDate}</time>
        <h1>{entry.data.title}</h1>
        {entry.data.description && <p class="blog-post__excerpt">{entry.data.description}</p>}
        {entry.data.author && <p class="blog-post__author">{entry.data.author}</p>}
        {entry.data.categories && entry.data.categories.length > 0 && (
          <ul class="blog-post__categories">
            {entry.data.categories.map((category) => (
              <li>{category}</li>
            ))}
          </ul>
        )}
      </div>
      <div class="blog-post__hero">
        <img src={featuredImage} alt={imageAlt} width="1200" height="630" loading="eager" />
      </div>
    </header>
    <div class="container blog-post__body prose reveal">
      <slot />
    </div>
  </article>
  <slot name="footer" slot="footer" />
</BaseLayout>

<style>
  .blog-post__header {
    padding-top: clamp(2rem, 5vw, 4rem);
  }

  .blog-post__date {
    display: block;
    font-size: 0.875rem;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .blog-post__author {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
  }

  .blog-post__categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1rem;
    padding: 0;
    list-style: none;
  }

  .blog-post__categories li {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    padding: 0.25rem 0.625rem;
  }

  .blog-post__excerpt {
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 42rem;
  }

  .blog-post__hero {
    margin-top: 2rem;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg-elevated);
  }

  .blog-post__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-post__body {
    padding-block: clamp(2rem, 4vw, 3.5rem);
  }
</style>
