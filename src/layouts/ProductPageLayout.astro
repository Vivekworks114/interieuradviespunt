---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  entry: CollectionEntry<'pages'>;
}

const { entry } = Astro.props;
const featuredImage = entry.data.featuredImage ?? '/images/2023/05/wanddecoratie.jpg';
---
<BaseLayout title={entry.data.title} description={entry.data.description} image={featuredImage}>
  <slot name="header" slot="header" />
  <article class="product-page-wrapper">
    <slot />
  </article>
  <slot name="footer" slot="footer" />
</BaseLayout>

<link rel="stylesheet" href="/css/elementor-post-17.css" />

<style is:global>
  .product-page-wrapper {
    padding-block: clamp(1.5rem, 4vw, 3rem);
  }

  .product-page-wrapper .product-page {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: clamp(1rem, 3vw, 1.5rem);
  }

  .product-page-wrapper .elementor-section {
    margin-bottom: 0;
  }

  .product-page-wrapper h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .product-page-wrapper h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    color: var(--color-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .product-page-wrapper h3 {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    color: var(--color-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .product-page-wrapper h4 {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .product-page-wrapper p,
  .product-page-wrapper li {
    color: var(--color-muted);
    line-height: 1.7;
  }

  .product-page-wrapper a:not(.elementor-button) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .product-page-wrapper img {
    max-width: 100%;
    height: auto;
  }

  .product-page-wrapper .product-stars {
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }

  .product-page-wrapper .elementor-button,
  .product-page-wrapper a.elementor-button,
  .product-page-wrapper .elementor-button-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--color-accent) !important;
    color: #fff !important;
    text-decoration: none !important;
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    border: none;
    transition: background var(--transition);
  }

  .product-page-wrapper .elementor-button:hover,
  .product-page-wrapper a.elementor-button:hover {
    background: var(--color-accent-hover) !important;
  }

  .product-page-wrapper .elementor-accordion-item {
    border-bottom: 1px solid var(--color-border);
  }

  .product-page-wrapper .elementor-accordion-title {
    display: block;
    padding: 1rem 0;
    color: var(--color-primary);
    cursor: pointer;
    font-family: var(--font-heading);
  }

  .product-page-wrapper .elementor-accordion-content {
    padding-bottom: 1rem;
    color: var(--color-muted);
  }

  .product-page-wrapper .elementor-author-box {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .product-page-wrapper .elementor-author-box__avatar img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
  }

  .product-page-wrapper .elementor-toc__header,
  .product-page-wrapper .elementor-widget-table-of-contents {
    background: var(--color-bg-elevated);
    padding: 1rem 1.25rem;
    margin-block: 1.5rem;
    border: 1px solid var(--color-border);
  }

  .product-page-wrapper .elementor-toc__list-item a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .product-page-wrapper .elementor-toc__list-item a:hover {
    color: var(--color-accent);
  }

  .product-page-wrapper .elementor-widget-divider {
    margin-block: 2rem;
  }

  .product-page-wrapper ul {
    padding-left: 1.25rem;
    margin-bottom: 1rem;
  }

  .product-page-wrapper ul li {
    margin-bottom: 0.35rem;
  }

  @media (max-width: 767px) {
    .product-page-wrapper .elementor-column {
      width: 100% !important;
    }
  }
</style>
