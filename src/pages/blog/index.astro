---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExactHeader from '../../components/ExactHeader.astro';
import ExactFooter from '../../components/ExactFooter.astro';
import BlogIndexPage from '../../components/BlogIndexPage.astro';

const PER_PAGE = 32;
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const totalPages = Math.max(1, Math.ceil(allPosts.length / PER_PAGE));
const page = 1;
const posts = allPosts.slice(0, PER_PAGE);
---
<BaseLayout title="Blog" description="Artikelen en blogs over interieur op Interieuradviespunt.nl">
  <ExactHeader slot="header" />
  <BlogIndexPage posts={posts} page={page} totalPages={totalPages} />
  <ExactFooter slot="footer" />
</BaseLayout>
