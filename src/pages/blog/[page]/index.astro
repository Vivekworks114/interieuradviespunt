---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ExactHeader from '../../../components/ExactHeader.astro';
import ExactFooter from '../../../components/ExactFooter.astro';
import BlogIndexPage from '../../../components/BlogIndexPage.astro';

const PER_PAGE = 32;

export async function getStaticPaths() {
  const PER_PAGE = 32;
  const allPosts = await getCollection('blog');
  const totalPages = Math.max(1, Math.ceil(allPosts.length / PER_PAGE));
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
    params: { page: String(i + 2) },
    props: { pageNumber: i + 2, totalPages },
  }));
}

const { pageNumber, totalPages } = Astro.props;
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const start = (pageNumber - 1) * PER_PAGE;
const posts = allPosts.slice(start, start + PER_PAGE);
---
<BaseLayout
  title={`Blog — pagina ${pageNumber}`}
  description="Artikelen en blogs over interieur op Interieuradviespunt.nl"
>
  <ExactHeader slot="header" />
  <BlogIndexPage posts={posts} page={pageNumber} totalPages={totalPages} />
  <ExactFooter slot="footer" />
</BaseLayout>
